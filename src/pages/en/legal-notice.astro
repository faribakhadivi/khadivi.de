---
import Layout from "@/layouts/Layout.astro";

const lang = "en";
---

<Layout lang={lang} title="Legal Notice — Fariba Khadivi">
  <section class="bg-white">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
      <h1 class="text-3xl md:text-4xl font-light text-black mb-12">Legal Notice (Impressum)</h1>

      <div class="prose prose-gray max-w-none prose-headings:font-light prose-headings:text-black prose-p:text-gray-600">
        <h2>Information pursuant to &sect; 5 TMG</h2>
        <p>
          Fariba Khadivi<br />
          Architect &amp; Energy Consultant<br />
          [Street and house number]<br />
          [Postal code, City]<br />
          Germany
        </p>

        <h2>Contact</h2>
        <p>
          Email: <a href="mailto:architektin-fariba@khadivi.de">architektin-fariba@khadivi.de</a>
        </p>

        <h2>Professional Title and Regulatory Information</h2>
        <p>
          Professional title: Architect (Architektin)<br />
          Granted in: [Federal State], Germany<br />
          Competent chamber: [Chamber of Architects]<br />
          [Membership number]
        </p>

        <h2>Dispute Resolution</h2>
        <p>
          The European Commission provides a platform for online dispute resolution (OS):
          <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">https://ec.europa.eu/consumers/odr/</a>.<br />
          Our email address can be found above.
        </p>
        <p>
          We are not willing or obliged to participate in dispute resolution proceedings before a consumer arbitration board.
        </p>

        <hr class="my-8 border-gray-200" />
        <p class="text-sm text-gray-400">
          [Note: This legal notice is a placeholder. Please complete with actual details and have it reviewed by a legal professional.]
        </p>
      </div>
    </div>
  </section>
</Layout>
