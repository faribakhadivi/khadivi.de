---
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { t } from "@/i18n";
import { getCollection } from "astro:content";

const lang = "en";
const i = t(lang);

const projects = (await getCollection("projekte"))
  .filter((p) => p.data.lang === "en")
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout lang={lang}>
  <!-- Hero Section -->
  <section class="relative bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-40">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-widest text-gray-400 mb-4">
          {i.hero.title}
        </p>
        <h1 class="text-4xl md:text-6xl font-light text-black leading-tight">
          {i.hero.name}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-gray-500 font-light leading-relaxed max-w-2xl">
          {i.hero.subtitle}
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/en/projects"
            class="inline-block px-8 py-3 bg-gray-900 text-white text-sm tracking-wide uppercase hover:bg-black transition-colors"
          >
            {i.hero.cta}
          </a>
          <a
            href="/en/contact"
            class="inline-block px-8 py-3 border border-gray-300 text-gray-700 text-sm tracking-wide uppercase hover:border-gray-900 hover:text-black transition-colors"
          >
            {i.hero.contact}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="bg-gray-50 border-y border-gray-200">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-light text-black mb-12">
        {i.office.services_title}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {i.office.service_categories.map((category) => (
          <div>
            <h3 class="text-lg font-medium text-black mb-4">{category.title}</h3>
            <div class="space-y-3">
              {category.items.map((item: string) => (
                <div class="flex items-start gap-3">
                  <span class="mt-1.5 w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"></span>
                  <span class="text-gray-600">{item}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12">
        <a
          href="/en/office"
          class="text-sm text-gray-500 hover:text-black transition-colors underline underline-offset-4"
        >
          Learn more about the practice &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-light text-black mb-12">
        {i.projects.heading}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            year={project.data.year}
            thumbnail={project.data.thumbnail}
            href={`/en/projects/${project.id.replace("en/", "")}`}
          />
        ))}
      </div>
      <div class="mt-12">
        <a
          href="/en/projects"
          class="text-sm text-gray-500 hover:text-black transition-colors underline underline-offset-4"
        >
          {i.projects.view_project} &rarr;
        </a>
      </div>
    </div>
  </section>
</Layout>
