---
import Layout from "@/layouts/Layout.astro";
import { t } from "@/i18n";

const lang = "de";
const i = t(lang);
---

<Layout lang={lang} title={`${i.office.title} — Fariba Khadivi`}>
  <!-- Page Header -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">
      <p class="text-sm uppercase tracking-widest text-gray-400 mb-4">
        Fariba Khadivi
      </p>
      <h1 class="text-3xl md:text-5xl font-light text-black">
        {i.office.heading}
      </h1>
      <p class="mt-6 text-lg text-gray-500 font-light max-w-2xl">
        {i.office.intro}
      </p>
    </div>
  </section>

  <!-- Experience -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-xl font-light text-black mb-6">
            {i.office.experience_title}
          </h2>
          <p class="text-gray-600 leading-relaxed">
            {i.office.experience_text}
          </p>
          <p class="mt-4 text-gray-500 text-sm leading-relaxed">
            [Dieser Text wird von Fariba ergänzt — hier können weitere Details zur beruflichen Laufbahn, Qualifikationen und besonderen Kompetenzen eingefügt werden.]
          </p>
        </div>

        <div>
          <h2 class="text-xl font-light text-black mb-6">
            {i.office.services_title}
          </h2>
          <div class="space-y-8">
            {i.office.service_categories.map((category) => (
              <div>
                <h3 class="text-lg font-medium text-black mb-4">{category.title}</h3>
                <ul class="space-y-3">
                  {category.items.map((item: string) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-2 w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"></span>
                      <span class="text-gray-600">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications placeholder -->
  <section class="bg-gray-50 border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="text-xl font-light text-black mb-6">
        Qualifikationen
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-sm text-gray-600">
        <div>
          <h3 class="font-medium text-gray-800 mb-2">Ausbildung</h3>
          <p>[Studium und Abschlüsse — von Fariba zu ergänzen]</p>
        </div>
        <div>
          <h3 class="font-medium text-gray-800 mb-2">Zertifizierungen</h3>
          <p>[Energieberaterzertifizierung, Kammermitgliedschaft etc. — von Fariba zu ergänzen]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-6 py-16 text-center">
      <p class="text-lg text-gray-500 font-light mb-6">
        Interesse an einer Zusammenarbeit?
      </p>
      <a
        href="/kontakt"
        class="inline-block px-8 py-3 bg-gray-900 text-white text-sm tracking-wide uppercase hover:bg-black transition-colors"
      >
        Kontakt aufnehmen
      </a>
    </div>
  </section>
</Layout>
